{
  "name": "drawflow-plus",
  "version": "0.2.0",
  "description": "Enhanced Drawflow library — node types, validation, state management, viewport, connection rules, canvas modes, multi-select, auto-save, minimap, and more",
  "main": "dist/drawflow-plus.umd.js",
  "module": "dist/drawflow-plus.esm.js",
  "browser": "dist/drawflow-plus.umd.js",
  "exports": {
    ".": {
      "import": "./dist/drawflow-plus.esm.js",
      "require": "./dist/drawflow-plus.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "dev": "vite build --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docs": "jsdoc -c jsdoc.json",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix"
  },
  "keywords": [
    "drawflow",
    "workflow",
    "visual-programming",
    "node-editor",
    "call-flow",
    "graph"
  ],
  "author": "md-riaz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/md-riaz/Drawflow-plus.git"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "babel-jest": "^29.5.0",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jsdoc": "^4.0.2",
    "vite": "^5.0.0"
  },
  "peerDependencies": {
    "drawflow": ">=0.0.47"
  },
  "peerDependenciesMeta": {
    "drawflow": {
      "optional": true
    }
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  }
}
