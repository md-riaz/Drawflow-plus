{
  "name": "drawflow-plus",
  "version": "0.1.0",
  "description": "Enhanced Drawflow library with extensions for node types, validation, state management, and connections",
  "main": "dist/drawflow-plus.js",
  "types": "dist/drawflow-plus.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev": "webpack --mode development --watch",
    "docs": "jsdoc -c jsdoc.json",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix"
  },
  "keywords": [
    "drawflow",
    "workflow",
    "visual-programming",
    "node-editor",
    "call-flow",
    "graph"
  ],
  "author": "md-riaz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/md-riaz/Drawflow-plus.git"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "babel-loader": "^9.1.0",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.0.0",
    "jsdoc": "^4.0.2",
    "webpack": "^5.87.0",
    "webpack-cli": "^5.1.0"
  },
  "peerDependencies": {
    "drawflow": "^1.1.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
